{% style %}
 .section-{{ section.id }}{
    background-color: {{ section.settings.background_color }};
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
 }
 @media screen and (max-width: 767px) {
    .section-{{ section.id }}{
        padding-top:{{ section.settings.mobile_padding_top }}px;
        padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
    }
 }
  .section-{{ section.id }} .image-grid-wrapper{
    gap: 20px;
  }
  .section-{{ section.id }} .image-grid-item{
    width: calc(100% / 3 - 13.34px);
    max-width: calc(100% / 3 - 13.34px);
    position: relative;
  }
  .section-{{ section.id }} .image-grid-item img{
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }
  .section-{{ section.id }} .quick-add{
    position: absolute;
    width: 22px;
    height: 22px;
    background-color: #fff;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }
  .section-{{ section.id }} .quick-view-popup{
    display: none; 
  }
  @media screen and (max-width: 767px) {
    .section-{{ section.id }} .image-grid-wrapper{
        gap: 4px;
    }
    .section-{{ section.id }} .image-grid-item{
        width: calc(100% / 2 - 2px);
        max-width: calc(100% / 2 - 2px);
        position: relative;
    }
  }
{% endstyle %}
<div class="section-{{ section.id }}">
    <div class="page-width">
        <div class="image-grid-wrapper flex">
            {% for block in section.blocks %}
            <div class="image-grid-item">
                <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image.alt }}">
                <span class="quick-add" style="top:{{ block.settings.quick_add_top }}%;right:{{ block.settings.quick_add_right }}%;">
                <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M4.98047 0.75V9.21154" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
                    <path d="M0.75 4.98071H9.21154" stroke="black" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="round"/>
                </svg>
                </span>
            </div>
            <div class="quick-view-popup">
                <div class="quick-view-popup-inner">
                    <div class="quick-view-popup-image">
                        <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.image.alt }}">
                    </div>
                    <div class="quick-view-popup-content">
                        <h2>{{ block.settings.title }}</h2>
                        <p>{{ block.settings.price }}</p>
                        <p>{{ block.settings.description }}</p>
                        <a href="{{ block.settings.url }}" class="quick-view-popup-button">View Product</a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "Custom Image Grid",
    "settings": [
        {
            "type": "color",
            "id": "background_color",
            "label": "Background Color",
            "default": "#F5F5F5"
        },
        {
            "type": "range",
            "id": "padding_top",
            "label": "Padding Top",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "label": "Padding Bottom",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        },
        {
            "type": "range",
            "id": "mobile_padding_top",
            "label": "Mobile Padding Top",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        },
        {
            "type": "range",
            "id": "mobile_padding_bottom",
            "label": "Mobile Padding Bottom",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        }
    ],
    "blocks": [
        {
            "type": "image",
            "name": "Image",
            "limit": 6,
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image"
                },
                {
                    "type": "product",
                    "id": "product",
                    "label": "Product"
                },
                {
                    "type": "range",
                    "id": "quick_add_top",
                    "label": "Quick Add Top",
                    "default": 10,
                    "min": 0,
                    "max": 100,
                    "step": 1
                },
                {
                    "type": "range",
                    "id": "quick_add_right",
                    "label": "Quick Add Right",
                    "default": 10,
                    "min": 0,
                    "max": 100,
                    "step": 1
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Custom Image Grid"
        }
    ]
}
{% endschema %}