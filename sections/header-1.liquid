{% style %}
 .section-{{ section.id }}{
    background-color:{{ section.settings.background }};
    padding: 10px 0;
 }
 .section-{{ section.id }} .header-1-logo{
    width: {{ section.settings.logo_width }}px;
 }
 .section-{{ section.id }} .btn {
    background-color: {{ section.settings.btn_background }};
    color: {{ section.settings.btn_text_color }};
 }
 .section-{{ section.id }} .btn svg path {
    fill: {{ section.settings.btn_icon_color }};
 }
 .section-{{ section.id }} .btn::before {
    background: {{ section.settings.btn_hover_background }};
 }
 .section-{{ section.id }} .btn:hover {
    color: {{ section.settings.btn_hover_text_color }} !important;
    border-color: {{ section.settings.btn_hover_text_color }} !important;
 }
 .section-{{ section.id }} .btn:hover svg path {
    fill: {{ section.settings.btn_hover_icon_color }} !important;
 }
 .section-{{ section.id }} .mobile-menu-toggle,
 .section-{{ section.id }} .mobile-menu-panel{
    display: none;
 }
  @media screen and (max-width: 767px){
     .section-{{ section.id }}{
        padding: 25px 0;
     }
 }
{% endstyle %}

<header class="section-{{ section.id }}">
    <div class="page-width">
        <div class="header-1-wrapper flex justify-between align-center">
            <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-label="Open menu" data-mobile-menu-toggle>
                <span class="mobile-menu-toggle__open">
                    <svg width="20" height="12" viewBox="0 0 20 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 6H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M1 1H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M1 11H19" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
                <span class="mobile-menu-toggle__close">
                    <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 13.9994L13.7279 1.27147" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M1 1L13.7279 13.7279" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </span>
            </button>
            <a class="header-1-logo" href="{{ routes.root_url }}">
                {% if section.settings.logo %}
                <img src="{{ section.settings.logo | img_url: 'master' }}" alt="{{ section.settings.logo.alt }}">
                {% else %}
                <h1>{{ shop.name }}</h1>
                {% endif %}
            </a>
            <div class="announcementbar-text">
                <p>{{ section.settings.text }}</p>
            </div>
            {% render 'button', button_text: section.settings.btn_text, button_url: section.settings.btn_url %}
        </div>
        <div class="mobile-menu-panel" data-mobile-menu-panel>
            <div class="mobile-menu-panel__inner">
                <p>{{ section.settings.text }}</p>
                {% render 'button', button_text: section.settings.btn_text, button_url: section.settings.btn_url %}
            </div>
        </div>
    </div>
</header>

{% schema %}
{
    "name": "Header 1",
    "settings": [
        {
            "type": "color",
            "id": "background",
            "label": "Background Color",
            "default": "#F5F5F5"
        },
        {
            "type": "image_picker",
            "id": "logo",
            "label": "Logo"
        },
        {
            "type": "range",
            "id": "logo_width",
            "label": "Logo Width",
            "min": 50,
            "max": 200,
            "step": 2,
            "default": 154,
            "unit": "px"
        },
        {
            "type": "text",
            "id": "text",
            "label": "Text",
            "default": "Free Shipping on orders over $50"
        },
        {
            "type": "text",
            "id": "btn_text",
            "label": "Button Text",
            "default": "Shop Now"
        },
        {
            "type": "url",
            "id": "btn_url",
            "label": "Button URL"
        },
        {
            "type": "color",
            "id": "btn_background",
            "label": "Button Background",
            "default": "#FFF544"
        },
        {
            "type": "color",
            "id": "btn_text_color",
            "label": "Button Text Color",
            "default": "#000"
        },
        {
            "type": "color",
            "id": "btn_icon_color",
            "label": "Button Icon Color",
            "default": "#000"
        },
        {
            "type": "color",
            "id": "btn_hover_background",
            "label": "Button Hover Background Color",
            "default": "#000"
        },
        {
            "type": "color",
            "id": "btn_hover_text_color",
            "label": "Button Hover Text Color",
            "default": "#fff"
        },
        {
            "type": "color",
            "id": "btn_hover_icon_color",
            "label": "Button Hover Icon Color",
            "default": "#fff"
        }
    ],
    "blocks": [
        {
            "type": "link",
            "name": "Link",
            "limit": 6,
            "settings": [
                {
                    "type": "text",
                    "id": "title",
                    "label": "Title",
                    "default": "Menu"
                },
                {
                    "type": "url",
                    "id": "url",
                    "label": "URL"
                }
            ]
        }
    ]
}
{% endschema %}
