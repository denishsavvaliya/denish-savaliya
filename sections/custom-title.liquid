{% style %}
 .section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    text-align: {{ section.settings.text_alignment }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
 }
 .section-{{ section.id }} .heading-text {
    font-size: 36px;
    line-height: 1.2;
 }
 @media screen and (max-width: 767px) {
    .section-{{ section.id }} {
        text-align: {{ section.settings.text_alignment_mobile }};
        padding-top: {{ section.settings.mobile_padding_top }}px;
        padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
    .section-{{ section.id }} .heading-text {
        font-size: 24px;
    }
 }
{% endstyle %}

<!-- Title Block -->
<div class="section-{{ section.id }}">
    <div class="page-width">
        <h2 class="heading-text lustria-regular">{{ section.settings.text }}</h2>
    </div>
</div>

{% schema %}
{
    "name": "Custom Title",
    "settings": [
        {
            "type": "color",
            "id": "background_color",
            "label": "Background Color",
            "default": "#F5F5F5"
        },
        {
            "type": "text",
            "id": "text",
            "label": "Text"
        },
        {
            "type": "select",
            "id": "text_alignment",
            "label": "Text Alignment",
            "default": "left",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "select",
            "id": "text_alignment_mobile",
            "label": "Mobile Text Alignment",
            "default": "center",
            "options": [
                {
                    "value": "left",
                    "label": "Left"
                },
                {
                    "value": "center",
                    "label": "Center"
                },
                {
                    "value": "right",
                    "label": "Right"
                }
            ]
        },
        {
            "type": "range",
            "id": "padding_top",
            "label": "Padding Top",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        },
        {
            "type": "range",
            "id": "padding_bottom",
            "label": "Padding Bottom",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        },
        {
            "type": "range",
            "id": "mobile_padding_top",
            "label": "Mobile Padding Top",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        },
        {
            "type": "range",
            "id": "mobile_padding_bottom",
            "label": "Mobile Padding Bottom",
            "default": 0,
            "min": 0,
            "max": 100,
            "step": 1
        }
    ],
    "presets": [
        {
            "name": "Custom Title"
        }
    ]
}
{% endschema %}